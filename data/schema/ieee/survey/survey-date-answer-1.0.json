{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "$id": "https://w3id.org/ieee/ieee-1752-schema/survey-date-answer.json",
    "title": "Survey Answer: Date",
    "description": "This schema represents a (full or partial) date value answer to a survey question.",
    "type": "object",
    "definitions": {
        "answer": {
            "$ref": "survey-answer-1.0.json"
        }
    },
    "allOf": [
        {
            "$ref": "#/definitions/answer"
        },
        {
            "properties": {
                "value": {
                    "oneOf": [
                        {
                            "pattern": "^[0-9]{4}-[0-9]{2}-[0-9]{2}$"
                        },
                        {
                            "pattern": "^[0-9]{4}-[0-9]{2}$"
                        },
                        {
                            "pattern": "^[0-9]{4}$"
                        }
                    ]
                }
            }
        }
    ]
}
